<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>ReactiveProperty.R3.WPF</PackageId>
    <RootNamespace>Reactive.Bindings.R3</RootNamespace>
    <AssemblyName>ReactiveProperty.R3.WPF</AssemblyName>
    <TargetFrameworks>net8.0-windows;net9.0-windows;net10.0-windows</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\ReactiveProperty.Core\key.snk</AssemblyOriginatorKeyFile>
    <Description>ReactiveProperty.R3.WPF provides EventToReactiveCommand and EventToReactiveProperty trigger actions for R3-based WPF view models.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" />
    <PackageReference Include="R3" />
  </ItemGroup>

</Project>
