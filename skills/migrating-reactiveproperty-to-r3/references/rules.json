    {
      "ruleId": "RP-MANUAL-SCHEDULER",
      "symbol": "System.Reactive.Concurrency.IScheduler",
      "matchKind": "TypeReference",
      "target": "manualReview",
      "replacement": null,
      "usingAdd": [],
      "usingRemove": [],
      "manualReview": "A custom IScheduler argument that is neither the UI dispatcher nor the default cannot be translated mechanically. R3 time-based APIs take a TimeProvider and collection dispatch uses a SynchronizationContext. Choose the right TimeProvider/SynchronizationContext (or FrameProvider) for this call site.",
      "notes": "Applies to explicit IScheduler arguments passed to RP APIs (e.g. ScheduledNotifier, ReactiveTimer, collection-dispatch overloads)."
    }
  ]
