{
  "schemaVersion": 2,
  "rules": [
    {
      "ruleId": "RP-OBSERVE-PROPERTY",
      "symbol": "Reactive.Bindings.Extensions.INotifyPropertyChangedExtensions.ObserveProperty",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.ObservePropertyChanged",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings.Extensions"],
      "manualReview": null,
      "notes": "Same call-site lambda (x => x.Name). R3 uses Func + CallerArgumentExpression, not an Expression tree."
    },
    {
      "ruleId": "RP-PROP-SLIM",
      "symbol": "Reactive.Bindings.ReactivePropertySlim<T>",
      "matchKind": "TypeReference",
      "target": "r3-direct",
      "replacement": "R3.ReactiveProperty<T>",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "R3 ReactiveProperty<T> is the read/write slim property; same Value/IObservable semantics."
    },
    {
      "ruleId": "RP-READONLY-PROP-SLIM",
      "symbol": "Reactive.Bindings.ReadOnlyReactivePropertySlim<T>",
      "matchKind": "TypeReference",
      "target": "r3-direct",
      "replacement": "R3.ReadOnlyReactiveProperty<T>",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "R3 ReadOnlyReactiveProperty<T> is the slim read-only property."
    },
    {
      "ruleId": "RP-PROP-BINDING",
      "symbol": "Reactive.Bindings.ReactiveProperty<T>",
      "matchKind": "TypeReference",
      "target": "r3-direct",
      "replacement": "R3.BindableReactiveProperty<T>",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "R3 BindableReactiveProperty<T> raises PropertyChanged for XAML binding. If the property uses DataAnnotations validation, see RP-VALIDATABLE-PROP / call EnableValidation()."
    },
    {
      "ruleId": "RP-READONLY-PROP",
      "symbol": "Reactive.Bindings.ReadOnlyReactiveProperty<T>",
      "matchKind": "TypeReference",
      "target": "r3-direct",
      "replacement": "R3.ReadOnlyReactiveProperty<T>",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Use R3 BindableReactiveProperty<T> instead when the value is bound to XAML and must raise PropertyChanged."
    },
    {
      "ruleId": "RP-COMMAND",
