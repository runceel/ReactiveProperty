      "replacement": "R3.ReactiveCommand",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Generic Reactive.Bindings.ReactiveCommand<T> maps to R3.ReactiveCommand<T>."
    },
    {
      "ruleId": "RP-COMMAND-SLIM",
      "symbol": "Reactive.Bindings.ReactiveCommandSlim",
      "matchKind": "TypeReference",
      "target": "r3-direct",
      "replacement": "R3.ReactiveCommand",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
