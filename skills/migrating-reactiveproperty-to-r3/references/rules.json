      "replacement": "R3.ToReactiveCommand",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Convert an Observable<bool> can-execute source to an R3 ReactiveCommand."
    },
    {
      "ruleId": "RP-TO-READONLY-PROP-SLIM",
      "symbol": "Reactive.Bindings.ReactivePropertyExtensions.ToReadOnlyReactivePropertySlim",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.ToReadOnlyReactiveProperty",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Build a read-only property from an IObservable<T>/Observable<T> source."
    },
    {
      "ruleId": "RP-TO-READONLY-PROP",
      "symbol": "Reactive.Bindings.ReactivePropertyExtensions.ToReadOnlyReactiveProperty",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.ToBindableReactiveProperty",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "R3 ToBindableReactiveProperty produces a binding-friendly read property. Use ToReadOnlyReactiveProperty when XAML binding is not required."
    },
    {
      "ruleId": "RP-TO-PROP",
      "symbol": "Reactive.Bindings.ReactivePropertyExtensions.ToReactiveProperty",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.ToBindableReactiveProperty",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Creates a binding-friendly property seeded from the source observable."
    },
    {
      "ruleId": "RP-OBSERVABLE-INTEROP",
      "symbol": "System.IObservable<T>",
      "matchKind": "TypeReference",
      "target": "r3-direct",
      "replacement": "R3.Observable<T>",
      "usingAdd": ["R3"],
      "usingRemove": [],
      "manualReview": null,
      "notes": "ReactiveProperty types are System.IObservable<T>; their R3 replacements are R3 Observable<T>. Prefer the R3 shape end-to-end. At a boundary that still requires System.Reactive, bridge with R3's ToObservable() (System.IObservable<T> -> R3 Observable<T>) or AsSystemObservable() (R3 Observable<T> -> System.IObservable<T>)."
    },
    {
      "ruleId": "RP-VALIDATE-ATTRIBUTE",
      "symbol": "Reactive.Bindings.ReactivePropertyExtensions.SetValidateAttribute",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.BindableReactiveProperty<T>.EnableValidation",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "DataAnnotations validation on a single property: call EnableValidation() (or EnableValidation(selector)) on the R3 BindableReactiveProperty. For stream/async validation or observable error streams, use RP-VALIDATABLE-PROP instead."
    },
    {
      "ruleId": "RP-VALIDATABLE-PROP",
      "symbol": "Reactive.Bindings.ValidatableReactiveProperty<T>",
      "matchKind": "TypeReference",
      "target": "reactiveproperty-r3",
      "replacement": "Reactive.Bindings.R3.ValidatableReactiveProperty<T>",
      "usingAdd": ["Reactive.Bindings.R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Gap: stream/async validation, multi-error aggregation and observable error streams (ObserveErrorChanged/ObserveHasErrors). SetValidateNotifyError overloads mirror ReactiveProperty."
    },
    {
