    {
      "ruleId": "RP-TO-PROP",
      "symbol": "Reactive.Bindings.ReactiveProperty.ToReactiveProperty",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.ToBindableReactiveProperty",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Creates a binding-friendly property seeded from the source observable."
    },
    {
      "ruleId": "RP-OBSERVABLE-INTEROP",
      "symbol": "System.IObservable<T>",
      "matchKind": "TypeReference",
      "target": "manualReview",
      "replacement": null,
      "usingAdd": [],
      "usingRemove": [],
      "manualReview": "Do not blindly replace System.IObservable<T> with R3 Observable<T>: public API signatures, third-party Rx boundaries, and code that intentionally keeps System.Reactive would break. Prefer the R3 shape end-to-end inside rewritten code, but at any boundary that still requires System.Reactive, bridge explicitly with R3's ToObservable() (System.IObservable<T> -> R3 Observable<T>) or AsSystemObservable() (R3 Observable<T> -> System.IObservable<T>) instead of changing the declared type.",
      "notes": "ReactiveProperty types are System.IObservable<T>; their R3 replacements are R3 Observable<T>. Type-level interop is a manual decision per call site, not a mechanical TypeReference swap."
    },
    {
      "ruleId": "RP-VALIDATE-ATTRIBUTE",
      "symbol": "Reactive.Bindings.ReactivePropertyExtensions.SetValidateAttribute",
      "matchKind": "MethodInvocation",
      "target": "r3-direct",
      "replacement": "R3.BindableReactiveProperty<T>.EnableValidation",
      "usingAdd": ["R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "DataAnnotations validation on a single property. SetValidateAttribute is an extension; EnableValidation is an INSTANCE method on R3 BindableReactiveProperty<T>. Rewrite the call as an instance invocation on the property: prop.SetValidateAttribute(() => x.Name) -> prop.EnableValidation(() => x.Name) (or parameterless prop.EnableValidation()). Do not emit the replacement as a static R3.BindableReactiveProperty<T>.EnableValidation(...) call. For stream/async validation or observable error streams, use RP-VALIDATABLE-PROP instead."
    },
    {
      "ruleId": "RP-VALIDATABLE-PROP",
      "symbol": "Reactive.Bindings.ValidatableReactiveProperty<T>",
      "matchKind": "TypeReference",
      "target": "reactiveproperty-r3",
      "replacement": "Reactive.Bindings.R3.ValidatableReactiveProperty<T>",
      "usingAdd": ["Reactive.Bindings.R3"],
      "usingRemove": ["Reactive.Bindings"],
      "manualReview": null,
      "notes": "Gap: stream/async validation, multi-error aggregation and observable error streams (ObserveErrorChanged/ObserveHasErrors). SetValidateNotifyError overloads mirror ReactiveProperty."
    },
